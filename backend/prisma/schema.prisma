generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKSHOP_STAFF
  MANAGER
}

enum VehicleStatus {
  AVAILABLE
  IN_SERVICE
  UNDER_REPAIR
  OUT_OF_SERVICE
}

enum JobCardStatus {
  INTAKE
  DIAGNOSIS
  REPAIR
  TESTING
  COMPLETED
  CANCELLED
}

enum TransactionType {
  IN
  OUT
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(WORKSHOP_STAFF)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  jobCards  JobCard[] @relation("AssignedTechnician")
}

model Vehicle {
  id             String        @id @default(uuid())
  plateNumber    String        @unique
  make           String
  model          String
  year           Int
  color          String?
  vin            String?       @unique
  assignedDriver String?
  status         VehicleStatus @default(AVAILABLE)
  mileage        Int           @default(0)
  fuelType       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  jobCards       JobCard[]
}

model JobCard {
  id               String          @id @default(uuid())
  jobNumber        String          @unique
  vehicleId        String
  vehicle          Vehicle         @relation(fields: [vehicleId], references: [id])
  technicianId     String?
  technician       User?           @relation("AssignedTechnician", fields: [technicianId], references: [id])
  status           JobCardStatus   @default(INTAKE)
  priority         String          @default("NORMAL")
  description      String
  estimatedCost    Float?
  actualCost       Float?
  intakeDate       DateTime        @default(now())
  completionDate   DateTime?
  notes            String?
  mileageAtService Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  repairs          Repair[]
  statusHistory    JobCardHistory[]
}

model JobCardHistory {
  id        String        @id @default(uuid())
  jobCardId String
  jobCard   JobCard       @relation(fields: [jobCardId], references: [id])
  status    JobCardStatus
  notes     String?
  changedBy String?
  changedAt DateTime      @default(now())
}

model Repair {
  id          String       @id @default(uuid())
  jobCardId   String
  jobCard     JobCard      @relation(fields: [jobCardId], references: [id])
  description String
  laborCost   Float        @default(0)
  laborHours  Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  parts       RepairPart[]
}

model Part {
  id            String                 @id @default(uuid())
  partNumber    String                 @unique
  name          String
  description   String?
  category      String?
  unitCost      Float
  quantity      Int                    @default(0)
  minimumStock  Int                    @default(5)
  unit          String                 @default("piece")
  supplier      String?
  location      String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  repairParts   RepairPart[]
  transactions  InventoryTransaction[]
}

model RepairPart {
  id        String   @id @default(uuid())
  repairId  String
  repair    Repair   @relation(fields: [repairId], references: [id])
  partId    String
  part      Part     @relation(fields: [partId], references: [id])
  quantity  Int
  unitCost  Float
  totalCost Float
  createdAt DateTime @default(now())
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  partId      String
  part        Part            @relation(fields: [partId], references: [id])
  type        TransactionType
  quantity    Int
  reason      String?
  reference   String?
  performedBy String?
  createdAt   DateTime        @default(now())
}