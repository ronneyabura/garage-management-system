generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  WORKSHOP_STAFF
  MANAGER
}

enum VehicleStatus {
  AVAILABLE
  IN_SERVICE
  UNDER_REPAIR
  OUT_OF_SERVICE
}

enum JobCardStatus {
  INTAKE
  DIAGNOSIS
  REPAIR
  TESTING
  COMPLETED
  CANCELLED
}

enum TransactionType {
  IN
  OUT
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(WORKSHOP_STAFF)
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedJobCards JobCard[] @relation("TechnicianJobCards")
  createdJobCards  JobCard[] @relation("CreatedByJobCards")
  auditLogs        AuditLog[]
}

model Vehicle {
  id             String        @id @default(uuid())
  plateNumber    String        @unique
  make           String
  model          String
  year           Int
  vin            String?       @unique
  color          String?
  mileage        Int           @default(0)
  assignedDriver String?
  status         VehicleStatus @default(AVAILABLE)
  fuelType       String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  jobCards       JobCard[]
}

model JobCard {
  id            String        @id @default(uuid())
  jobNumber     String        @unique
  vehicleId     String
  technicianId  String?
  createdById   String
  status        JobCardStatus @default(INTAKE)
  priority      String        @default("NORMAL")
  description   String
  diagnosis     String?
  workDone      String?
  estimatedCost Float?
  actualCost    Float?
  mileageIn     Int?
  mileageOut    Int?
  scheduledDate DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
  technician  User?         @relation("TechnicianJobCards", fields: [technicianId], references: [id])
  createdBy   User          @relation("CreatedByJobCards", fields: [createdById], references: [id])
  repairs     Repair[]
  statusLogs  StatusLog[]
}

model Repair {
  id          String   @id @default(uuid())
  jobCardId   String
  description String
  laborCost   Float    @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobCard     JobCard       @relation(fields: [jobCardId], references: [id])
  parts       RepairPart[]
}

model Part {
  id           String   @id @default(uuid())
  partNumber   String?  @unique
  name         String
  description  String?
  category     String?
  quantity     Int      @default(0)
  minQuantity  Int      @default(5)
  unitCost     Float
  unitPrice    Float?
  supplier     String?
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  repairParts          RepairPart[]
  inventoryTransactions InventoryTransaction[]
}

model RepairPart {
  id        String   @id @default(uuid())
  repairId  String
  partId    String
  quantity  Int
  unitCost  Float
  createdAt DateTime @default(now())

  repair Repair @relation(fields: [repairId], references: [id])
  part   Part   @relation(fields: [partId], references: [id])
}

model InventoryTransaction {
  id          String          @id @default(uuid())
  partId      String
  type        TransactionType
  quantity    Int
  reference   String?
  notes       String?
  createdById String?
  createdAt   DateTime        @default(now())

  part Part @relation(fields: [partId], references: [id])
}

model StatusLog {
  id        String        @id @default(uuid())
  jobCardId String
  status    JobCardStatus
  notes     String?
  createdAt DateTime      @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
